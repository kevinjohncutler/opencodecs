# Build artifacts
build/
dist/
*.egg-info/
*.so
*.pyd
*.dll

# Local test-data downloads (large reference files cached for tests)
.test_data/
tests/.test_data/

# Cython-generated C (matches every _*.pyx → _*.c). Hand-written C
# helpers (e.g. b2nd_helpers.c) are NOT prefixed with _ and pass through.
src/opencodecs/codecs/_*.c

# Vendored libjxl build (rebuilt via bench/build_libjxl.sh)
vendor/libjxl/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.testmondata*
.coverage*

# Editor / OS
.DS_Store
._*
*.swp
.vscode/
.idea/

# Bench output
bench_data/
